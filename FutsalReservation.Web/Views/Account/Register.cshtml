@model RegisterVm
@{
    ViewData["Title"] = "Daftar";
    Layout = "_LayoutAuth";
}

<div class="auth-card">
    <div class="auth-head">
        <h1>Buat Akun Baru</h1>
        <p>Daftar untuk mulai memesan lapangan</p>
    </div>
    <div class="auth-body">
        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-error" role="alert"></div>

            <div class="form-grup">
                <label asp-for="Nama"></label>
                <input asp-for="Nama" class="form-control" placeholder="Nama lengkap" />
                <span asp-validation-for="Nama" class="field-error"></span>
            </div>

            <div class="form-grup">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" placeholder="nama@email.com" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="form-grup">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" placeholder="Minimal 6 karakter" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="form-grup">
                <label asp-for="KonfirmasiPassword"></label>
                <input asp-for="KonfirmasiPassword" class="form-control" placeholder="Ulangi password" />
                <span asp-validation-for="KonfirmasiPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-block">
                @Html.Ikon("check", "icon-sm") Daftar
            </button>
        </form>

        <div class="auth-footer">
            Sudah punya akun? <a asp-action="Login">Masuk di sini</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
