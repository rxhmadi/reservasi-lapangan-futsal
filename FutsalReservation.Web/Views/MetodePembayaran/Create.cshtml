@model MetodePembayaranVm
@{
    ViewData["Title"] = "Tambah Metode Pembayaran";
    ViewData["Subtitle"] = "Tambahkan rekening bank, e-wallet, atau opsi bayar di tempat.";
}

@section HeaderActions {
    <a class="btn btn-outline btn-sm" asp-action="Index">@Html.Ikon("arrow-left", "icon-sm") Kembali</a>
}

<div class="card" style="max-width:640px">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-error"></div>
            <partial name="_Form" model="Model" />
            <button type="submit" class="btn btn-primary">@Html.Ikon("check", "icon-sm") Simpan</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
